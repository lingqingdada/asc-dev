#include "acl/acl.h"
#include "kernel_operator.h"
#include "data_utils.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

template <typename T>
__simd_vf__ inline void AddVF(__ubuf__ T* dstAddr, __ubuf__ T* src0Addr, __ubuf__ T* src1Addr, uint16_t oneRepeatSize,
                              uint32_t repeatTimes, uint32_t count)
{
    AscendC::Reg::RegTensor<T> reg0, reg1;
    AscendC::Reg::MaskReg mask;
    for (uint16_t i = 0; i < repeatTimes; i++) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        AscendC::Reg::LoadAlign(reg0, src0Addr + i * oneRepeatSize);
        AscendC::Reg::LoadAlign(reg1, src1Addr + i * oneRepeatSize);
        AscendC::Reg::Add(reg0, reg0, reg1, mask);
        AscendC::Reg::StoreAlign(dstAddr + i * oneRepeatSize, reg0, mask);
    }
}

template <typename T>
__simd_vf__ inline void SubVF(__ubuf__ T* dstAddr, __ubuf__ T* src0Addr, __ubuf__ T* src1Addr, uint16_t oneRepeatSize,
                              uint32_t repeatTimes, uint32_t count)
{
    AscendC::Reg::RegTensor<T> reg0, reg1, reg2;
    AscendC::Reg::MaskReg mask;
    for (uint16_t i = 0; i < repeatTimes; i++) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        AscendC::Reg::LoadAlign(reg0, src0Addr + i * oneRepeatSize);
        AscendC::Reg::LoadAlign(reg1, src1Addr + i * oneRepeatSize);
        AscendC::Reg::Sub(reg2, reg0, reg1, mask);
        // 保存计算结果到dstAddr，覆盖上一次的结果。该样例目的是为了演示LocalMenBar的用法
        AscendC::Reg::StoreAlign(dstAddr, reg2, mask);
        // 写同一地址，需要加上LocalMemBar
        AscendC::Reg::LocalMemBar<AscendC::Reg::MemType::VEC_STORE,
                                           AscendC::Reg::MemType::VEC_STORE>();
    }
}

template <typename T>
class Kernel {
public:
    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y, GM_ADDR z, uint32_t count)
    {
        this->count = count;
        this->xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        this->yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y));
        this->zGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(z));
    }
    __aicore__ inline void Process()
    {
        // 使用 LocalMemAllocator 分配 UB 内存
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T>(count);
        AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T>(count);
        AscendC::LocalTensor<T> zLocal = ubAllocator.Alloc<T>(count);

        // CopyIn: GM -> UB
        AscendC::DataCopy(xLocal, xGm, count);
        AscendC::DataCopy(yLocal, yGm, count);
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        // Compute: 使用 VF_CALL 进行 RegBase 计算，通过编译期宏选择场景
        __ubuf__ T* src0Addr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
        __ubuf__ T* src1Addr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
        __ubuf__ T* dstAddr = reinterpret_cast<__ubuf__ T*>(zLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
        uint16_t repeatTimes = AscendC::CeilDivision(count, oneRepeatSize);
        if constexpr (scenarioNum == 1) {
            // 场景1：加法场景（AddVF），通过寄存器保序优化读操作与写操作之间的同步
            AscendC::VF_CALL<AddVF<T>>(dstAddr, src0Addr, src1Addr, oneRepeatSize, repeatTimes, count);
        } else if constexpr (scenarioNum == 2) {
            // 场景2：减法场景（SubVF），插入LocalMemBar保证写操作与写操作之间的同步
            AscendC::VF_CALL<SubVF<T>>(dstAddr, src0Addr, src1Addr, oneRepeatSize, repeatTimes, count);
        }

        // CopyOut: UB -> GM
        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::DataCopy(zGm, zLocal, count);
    }

private:
    uint32_t count;
    AscendC::GlobalTensor<T> xGm, yGm, zGm;
};

__global__ __vector__ void reg_sync(GM_ADDR x, GM_ADDR y, GM_ADDR z)
{
    AscendC::InitSocState();
    Kernel<float> kernel;
    kernel.Init(x, y, z, 1024);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

static bool CompareResult(const void* outputData, uint32_t outSize)
{
    void* goldenData;
    aclrtMallocHost((void**)(&goldenData), outSize);
    size_t goldenSize = outSize;

    bool ret = ReadFile("./output/golden.bin", goldenSize, goldenData, goldenSize);
    if (ret) {
        printf("ReadFile golden.bin success!\n");
    } else {
        printf("test failed!\n");
        return false;
    }

    constexpr float EPS = 1e-4;
    int64_t wrongNum = 0;

    size_t checkSize = outSize;
    if constexpr (scenarioNum == 2) {
        // 场景2只校验前256byte
        checkSize = 256;
    }

    for (size_t i = 0; i < checkSize / sizeof(float); i++) {
        float a = (reinterpret_cast<const float*>(outputData))[i];
        float b = (reinterpret_cast<const float*>(goldenData))[i];
        float ae = std::abs(a - b);
        float re = ae / std::abs(b + EPS);
        if (ae > EPS && re > EPS) {
            printf("CompareResult golden.bin failed output is %lf, golden is %lf\n", a, b);
            wrongNum++;
        }
    }

    aclrtFreeHost(goldenData);
    if (wrongNum != 0) {
        return false;
    } else {
        printf("CompareResult golden.bin success!\n");
        return true;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    uint32_t count = 1024;
    size_t aInputByteSize = static_cast<size_t>(1) * count * sizeof(float);
    size_t bInputByteSize = static_cast<size_t>(1) * count * sizeof(float);
    size_t outputByteSize = static_cast<size_t>(1) * count * sizeof(float);
    uint8_t *xHost, *yHost, *zHost;
    uint8_t *xDevice, *yDevice, *zDevice;
    aclrtMallocHost((void**)(&xHost), aInputByteSize);
    aclrtMallocHost((void**)(&yHost), bInputByteSize);
    aclrtMallocHost((void**)(&zHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, aInputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, bInputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    ReadFile("./input/input_x.bin", aInputByteSize, xHost, aInputByteSize);
    ReadFile("./input/input_y.bin", bInputByteSize, yHost, bInputByteSize);
    aclrtMemcpy(xDevice, aInputByteSize, xHost, aInputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    aclrtMemcpy(yDevice, bInputByteSize, yHost, bInputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    reg_sync<<<numBlocks, nullptr, stream>>>(xDevice, yDevice, zDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);
    bool goldenResult = true;
    goldenResult = CompareResult(zHost, outputByteSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }
    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);
    aclrtFreeHost(zHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}