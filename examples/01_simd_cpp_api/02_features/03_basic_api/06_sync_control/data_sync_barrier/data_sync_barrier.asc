/* !
 * \file data_sync_barrier.asc
 * \brief
 */

#include <vector>
#include <cmath>
#include <cstdio>
#include "acl/acl.h"
#include "kernel_operator.h"

constexpr uint32_t calCount = 8;
constexpr int32_t value = 6;
template <typename T>
class KernelDataSyncBarrier {
public:
    __aicore__ inline KernelDataSyncBarrier() {}
    __aicore__ inline void Init(GM_ADDR srcGm, GM_ADDR dstGm, AscendC::TPipe *pipeIn, uint32_t calCount)
    {
        pipe = pipeIn;
        bufferSize = calCount;
        blockIdx = AscendC::GetBlockIdx();

        srcGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T *>(srcGm));
        dstGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ T *>(dstGm));

        pipe->InitBuffer(inQueue, 1, bufferSize * sizeof(T));
        pipe->InitBuffer(outQueue, 1, bufferSize * sizeof(T));
    }
    __aicore__ inline void Process(GM_ADDR srcGm, GM_ADDR dstGm)
    {
        if (blockIdx == 1) {
            while(true){
                __gm__ T *addr = const_cast<__gm__ T *>(srcGlobal.GetPhyAddr());
                T value = AscendC::ReadGmByPassDCache<T>(addr);
                if(value == 6){
                    __gm__ T *addr = const_cast<__gm__ T *>(srcGlobal.GetPhyAddr());
                    T valueNew = AscendC::ReadGmByPassDCache<T>(addr+1);
                    AscendC::printf("GM上addr+1位置的值：%u\n",valueNew);
                    AscendC::WriteGmByPassDCache<T>(reinterpret_cast<__gm__ T *>(dstGm), 2 * valueNew);
                    return;
                }
            }
        }
        if (blockIdx == 0) {
            AscendC::WriteGmByPassDCache<T>(reinterpret_cast<__gm__ T *>(srcGm)+1, value+1);
            AscendC::DataSyncBarrier<AscendC::MemDsbT::DDR>(); // 三种取值，ALL(包含DDR+UB)、DDR、UB
            AscendC::WriteGmByPassDCache<T>(reinterpret_cast<__gm__ T *>(srcGm), value); // value = 6
        }
    }

private:
    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<T> dstGlobal;
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueue;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueue;
    uint32_t bufferSize = 0;
    int32_t blockIdx = 0;
};

extern "C" __global__ __vector__ void kernel_data_sync_barrier(GM_ADDR srcGm, GM_ADDR dstGm)
{
    AscendC::TPipe pipe;
    KernelDataSyncBarrier<int32_t> op;
    op.Init(srcGm, dstGm, &pipe, calCount);
    op.Process(srcGm, dstGm);
}

static bool CompareResult(const void* outputData, const void* goldenData, uint32_t outSize)
{
    size_t goldenSize = outSize;
    constexpr int32_t EPS = 0;
    int64_t wrongNum = 0;

    for (size_t i = 0; i < outSize / sizeof(int32_t); i++) {
        int32_t a = (reinterpret_cast<const int32_t*>(outputData))[i];
        int32_t b = (reinterpret_cast<const int32_t*>(goldenData))[i];
        int32_t ae = std::abs(a - b);
        // 误差超过阈值则计数并打印
        if (ae > EPS) {
            printf("CompareResult failed output is %d, golden is %d\n", a, b);
            wrongNum++;
        }
    }
    if (wrongNum != 0) {
        return false;
    } else {
        return true;
    }
}

// 定义返回结构体
struct GoldenData {
    std::vector<int32_t> src;
    std::vector<int32_t> golden;
};

GoldenData gen_golden_data()
{
    std::vector<int32_t> src(calCount, 1);
    std::vector<int32_t> golden(calCount, 0);
    golden[0] = 2 * (value + 1);
    return {src, golden};
}

int32_t main(int32_t argc, char* argv[]) 
{
    uint32_t numBlocks = 2;
    size_t inputByteSize = calCount * sizeof(int32_t);
    size_t outputByteSize = inputByteSize;

    auto genData = gen_golden_data();
    auto src = genData.src;
    auto golden = genData.golden;
    uint8_t* goldenHost = reinterpret_cast<uint8_t*>(golden.data());

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *zHost;
    uint8_t *xDevice, *zDevice;
    uint8_t* xHost = reinterpret_cast<uint8_t*>(src.data());

    aclrtMallocHost((void **)(&xHost), inputByteSize);
    aclrtMallocHost((void **)(&zHost), outputByteSize);
    aclrtMalloc((void **)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize,
                ACL_MEMCPY_HOST_TO_DEVICE);

    kernel_data_sync_barrier<<<numBlocks, nullptr, stream>>>(xDevice, zDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize,
                ACL_MEMCPY_DEVICE_TO_HOST);
    bool goldenResult = true;
    goldenResult = CompareResult(zHost, goldenHost, outputByteSize);
    if (goldenResult) {
        printf("test pass!\n");
    } else {
        printf("test failed!\n");
    }

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
