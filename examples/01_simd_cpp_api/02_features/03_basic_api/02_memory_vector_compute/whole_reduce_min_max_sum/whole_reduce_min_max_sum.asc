/* !
 * \file whole_reduce_min_max_sum.asc
 * \brief 演示归约类接口在多场景下的使用方法，支持通过编译参数切换WholeReduceMax、WholeReduceMin、WholeReduceSum、RepeatReduceSum场景，配合GetReduceRepeatMaxMinSpr获取极值及索引，支持非对齐数据归约
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

constexpr uint32_t scenarioNum = SCENARIO_NUM;

// 场景1：WholeReduceMax，输入[1, 1024]，输出[1, 16]，每个repeat内求最大值及索引
// 场景2：WholeReduceMin，输入[1, 1024]，输出[1, 16]，每个repeat内求最小值及索引
// 场景3：WholeReduceSum，输入[1, 2048]，输出[1, 16]，每个repeat内求和
// 场景4：RepeatReduceSum，输入[1, 2048]，输出[1, 16]，每个repeat内求和（累加模式）
// 场景5：WholeReduceMax + GetReduceMaxMinCount，输入[1, 1024]，输出[1, 16]，求全局最大值及索引
// 场景6：WholeReduceMin + GetReduceMaxMinCount，输入[1, 1024]，输出[1, 16]，求全局最小值及索引
// 场景7：WholeReduceSum非对齐场景，输入[13, 123]，输出[1, 13]，对每行非对齐数据求和
constexpr uint32_t SRC_TOTAL_LENGTH = (scenarioNum == 3 || scenarioNum == 4) ? 2048 :
                                       scenarioNum == 7 ? 13 * 123 : 1024;
constexpr uint32_t DST_TOTAL_LENGTH = scenarioNum == 7 ? 13 : 16;
constexpr uint32_t MASK = 128;
constexpr uint32_t BYTE_ALIGN = 32;
constexpr uint32_t SRC_ROW = (scenarioNum == 7) ? 13 : 1;
constexpr uint32_t SRC_COL = (scenarioNum == 7) ? 123 : SRC_TOTAL_LENGTH;
constexpr uint32_t COL_ALIGN_BYTES = ((SRC_COL * sizeof(half) + BYTE_ALIGN - 1) / BYTE_ALIGN) * BYTE_ALIGN;
constexpr uint32_t SRC_BUFFER_LENGTH = SRC_ROW * (COL_ALIGN_BYTES / sizeof(half));

/**
 * @brief 归约样例的Kernel类，实现WholeReduceMax/Min/Sum、RepeatReduceSum和GetReduceRepeatMaxMinSpr功能
 */
class KernelReduce {
public:
    __aicore__ inline KernelReduce() {}
    __aicore__ inline void Init(__gm__ uint8_t* src, __gm__ uint8_t* dstGm, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        srcGlobal.SetGlobalBuffer((__gm__ half*)src);
        dstGlobal.SetGlobalBuffer((__gm__ half*)dstGm);
        repeat = SRC_TOTAL_LENGTH / MASK;
        pipe->InitBuffer(inQueueSrc, 1, SRC_BUFFER_LENGTH * sizeof(half));
        pipe->InitBuffer(outQueueDst, 1, DST_TOTAL_LENGTH * sizeof(half));
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }
private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<half> srcLocal = inQueueSrc.AllocTensor<half>();
        uint32_t colBytes = SRC_COL * sizeof(half);
        AscendC::DataCopyExtParams copyParams = {(uint16_t)SRC_ROW, colBytes, 0, 0, 0};
        uint8_t rpad = (COL_ALIGN_BYTES - colBytes) / sizeof(half);
        AscendC::DataCopyPadExtParams<half> padParams = {false, 0, rpad, 0};
        AscendC::DataCopyPad<half>(srcLocal, srcGlobal, copyParams, padParams);
        inQueueSrc.EnQue(srcLocal);
    }
    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<half> srcLocal = inQueueSrc.DeQue<half>();
        AscendC::LocalTensor<half> dstLocal = outQueueDst.AllocTensor<half>();

        if constexpr (scenarioNum == 1) {
            // 场景1：WholeReduceMax：对每个repeat内所有元素求最大值及其索引
            // mask=128, repeat=srcDataSize/mask, 使用默认order (ReduceOrder::ORDER_VALUE_INDEX)
            // 输出按值和索引交错存储：[max0, idx0, max1, idx1, ...]
            AscendC::WholeReduceMax<half>(dstLocal, srcLocal, MASK, repeat, 1, 1, 8);
        } else if constexpr (scenarioNum == 2) {
            // 场景2：WholeReduceMin：对每个repeat内所有元素求最小值及其索引
            // mask=128, repeat=srcDataSize/mask, 使用默认order (ReduceOrder::ORDER_VALUE_INDEX)
            // 输出按值和索引交错存储：[min0, idx0, min1, idx1, ...]
            AscendC::WholeReduceMin<half>(dstLocal, srcLocal, MASK, repeat, 1, 1, 8);
        } else if constexpr (scenarioNum == 3) {
            // 场景3：WholeReduceSum：对每个repeat内所有元素求和
            // mask=128, repeat=srcDataSize/mask, 每个repeat输出一个求和结果
            AscendC::WholeReduceSum<half>(dstLocal, srcLocal, MASK, repeat, 1, 1, 8);
        } else if constexpr (scenarioNum == 4) {
            // 场景4：RepeatReduceSum：对每个repeat内所有元素求和（累加模式）
            // 先将dstLocal初始化为0，再将所有repeat的结果累加
            // mask=128, repeat=srcDataSize/mask
            // dstBlkStride=0表示每个repeat的结果累加到同一个位置
            half zero(0);
            AscendC::Duplicate(dstLocal, zero, DST_TOTAL_LENGTH);
            AscendC::PipeBarrier<PIPE_V>();
            AscendC::RepeatReduceSum<half>(dstLocal, srcLocal, repeat, MASK, 0, 1, 1, 8);
        } else if constexpr (scenarioNum == 5) {
             // 场景5：WholeReduceMax + GetReduceRepeatMaxMinSpr
            // 对1024个half元素求全局最大值及其索引
            // mask逐bit模式, repeat=8(1024/128), srcBlkStride=1, srcRepeatStride=8
            // 8个repeat各自归约得到局部最大值，再通过GetReduceRepeatMaxMinSpr获取全局最大值
            uint64_t mask[2] = { 0xFFFFFFFFFFFFFFFF, 0xFFFFFFFFFFFFFFFF };
            AscendC::WholeReduceMax<half>(dstLocal, srcLocal, mask, repeat, 1, 1, 8);
            AscendC::PipeBarrier<PIPE_V>();
            half val = 0;
            half idx = 0;
            AscendC::GetReduceRepeatMaxMinSpr<half>(val, idx);
            AscendC::PipeBarrier<PIPE_V>();
            half zero{0};
            AscendC::Duplicate(dstLocal, zero, DST_TOTAL_LENGTH);
            int32_t eventIdVToS  = static_cast<int32_t>(GetTPipePtr()->FetchEventID(AscendC::HardEvent::V_S));
            AscendC::SetFlag<AscendC::HardEvent::V_S>(eventIdVToS);
            AscendC::WaitFlag<AscendC::HardEvent::V_S>(eventIdVToS);            
            dstLocal.SetValue(0, val);
            dstLocal.SetValue(1, idx);
        } else if constexpr (scenarioNum == 6) {
            // 场景6：WholeReduceMin + GetReduceRepeatMaxMinSpr
            // 对1024个half元素求全局最小值及其索引
            // mask逐bit模式, repeat=8(1024/128), srcBlkStride=1, srcRepeatStride=8
            // 8个repeat各自归约得到局部最小值，再通过GetReduceRepeatMaxMinSpr获取全局最小值
            uint64_t mask[2] = { 0xFFFFFFFFFFFFFFFF, 0xFFFFFFFFFFFFFFFF };
            AscendC::WholeReduceMin<half>(dstLocal, srcLocal, mask, repeat, 1, 1, 8);
            AscendC::PipeBarrier<PIPE_V>();
            half val = 0;
            half idx = 0;
            AscendC::GetReduceRepeatMaxMinSpr<half>(val, idx);
            AscendC::PipeBarrier<PIPE_V>();
            half zero{0};
            AscendC::Duplicate(dstLocal, zero, DST_TOTAL_LENGTH);
            int32_t eventIdVToS  = static_cast<int32_t>(GetTPipePtr()->FetchEventID(AscendC::HardEvent::V_S));
            AscendC::SetFlag<AscendC::HardEvent::V_S>(eventIdVToS);
            AscendC::WaitFlag<AscendC::HardEvent::V_S>(eventIdVToS);   
            dstLocal.SetValue(0, val);
            dstLocal.SetValue(1, idx);
        } else if constexpr (scenarioNum == 7) {
            // 场景7：WholeReduceSum按行求和非对齐场景
            // mask=SRC_COL(123)，每行123个元素求和
            // repeat=SRC_ROW(13)，共13行
            // srcRepeatStride=对齐后的步长（COL_ALIGN_BYTES/BYTE_ALIGN=8个block），即每行在LocalTensor中占128个元素
            int32_t srcStride = COL_ALIGN_BYTES / BYTE_ALIGN;
            AscendC::WholeReduceSum<half>(dstLocal, srcLocal, SRC_COL, SRC_ROW, 1, 1, srcStride);
        }

        outQueueDst.EnQue<half>(dstLocal);
        inQueueSrc.FreeTensor(srcLocal);
    }
    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<half> dstLocal = outQueueDst.DeQue<half>();
        uint16_t outBytes = DST_TOTAL_LENGTH * sizeof(half);
        AscendC::DataCopyExtParams copyParams = {1, outBytes, 0, 0, 0};
        AscendC::DataCopyPad<half>(dstGlobal, dstLocal, copyParams);
        outQueueDst.FreeTensor(dstLocal);
    }
private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueSrc;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueDst;
    AscendC::GlobalTensor<half> srcGlobal, dstGlobal;
    uint32_t repeat = 0;
};

__global__ __vector__ void reduce_custom(GM_ADDR x, GM_ADDR z)
{
    AscendC::TPipe pipe;
    KernelReduce op;
    op.Init(x, z, &pipe);
    op.Process();
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    size_t inputByteSize = SRC_TOTAL_LENGTH * sizeof(half);
    size_t outputByteSize = DST_TOTAL_LENGTH * sizeof(half);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;

    aclrtMallocHost((void **)(&xHost), inputByteSize);
    aclrtMallocHost((void **)(&zHost), outputByteSize);
    aclrtMalloc((void **)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize,
                ACL_MEMCPY_HOST_TO_DEVICE);

    reduce_custom<<<numBlocks, nullptr, stream>>>(xDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize,
                ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
