/* !
 * \file data_copy_pad.asc
 * \brief 演示使用DataCopyPad实现非32字节对齐数据搬运及填充功能
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

// 场景1：输入[1, 20]，输出[1, 32]，使用SetPadValue进行自定义填充
// 场景2：输入[32, 59]，输出[32, 64]，使用rightPadding进行默认
// 场景3：输入[3, 24]，输出[1, 80]，使用Compact模式，仅支持 Ascend 950PR/Ascend 950DT

#if defined(SCENARIO_NUM) && (SCENARIO_NUM == 1)
    constexpr uint32_t SRC_ROWS = 1;
    constexpr uint32_t SRC_COLS = 20;
    constexpr uint32_t DST_COLS = 32;
    constexpr uint32_t DST_TOTAL_LENGTH = SRC_ROWS * DST_COLS;
#elif defined(SCENARIO_NUM) && (SCENARIO_NUM == 2)
    constexpr uint32_t SRC_ROWS = 32;
    constexpr uint32_t SRC_COLS = 59;
    constexpr uint32_t DST_COLS = 64;
    constexpr uint32_t DST_TOTAL_LENGTH = SRC_ROWS * DST_COLS;
#elif defined(SCENARIO_NUM) && (SCENARIO_NUM == 3)
    constexpr uint32_t SRC_ROWS = 3;
    constexpr uint32_t SRC_COLS = 24;
    constexpr uint32_t DST_COLS = 80;
    constexpr uint32_t DST_TOTAL_LENGTH = DST_COLS;
#else
    constexpr uint32_t SRC_ROWS = 1;
    constexpr uint32_t SRC_COLS = 20;
    constexpr uint32_t DST_COLS = 32;
    constexpr uint32_t DST_TOTAL_LENGTH = SRC_ROWS * DST_COLS;
#endif

/**
 * @brief DataCopyPad样例的Kernel类，实现非32字节对齐数据搬运及填充功能
 */
template <typename T>
class KernelDataCopyPad {
public:
    __aicore__ inline KernelDataCopyPad() {}
    __aicore__ inline void Init(__gm__ uint8_t* srcGm, __gm__ uint8_t* dstGm, AscendC::TPipe* pipeIn)
    {
        pipe = pipeIn;
        srcGlobal.SetGlobalBuffer((__gm__ T*)srcGm);
        dstGlobal.SetGlobalBuffer((__gm__ T*)dstGm);
        pipe->InitBuffer(inQueueSrc, 1, SRC_ROWS * DST_COLS * sizeof(T));
        pipe->InitBuffer(outQueueDst, 1, DST_TOTAL_LENGTH * sizeof(T));
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        Compute();
        CopyOut();
    }
private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> srcLocal = inQueueSrc.AllocTensor<T>();
        
        if constexpr (scenarioNum == 1) {
            // 场景1：使用SetPadValue进行自定义填充
            // DataCopyExtParams参数：blockCount=1, blockLen=20*sizeof(half), srcBlkStride=0, srcRepStride=0, reserved=0
            // DataCopyPadExtParams参数：isPad=false, leftPadding=0, rightPadding=12
            // SetPadValue设置填充值为1，配合isPad=false使用
            AscendC::DataCopyExtParams copyParams{1, SRC_COLS * sizeof(T), 0, 0, 0}; 
            AscendC::DataCopyPadExtParams<T> padParams;
            padParams.isPad = false;
            padParams.leftPadding = 0;
            padParams.rightPadding = DST_COLS - SRC_COLS;
            
            AscendC::SetPadValue((T)1);
            AscendC::DataCopyPad(srcLocal, srcGlobal, copyParams, padParams); 
        } else if constexpr (scenarioNum == 2) {
            // 场景2：使用rightPadding进行默认填充
            // DataCopyExtParams参数：blockCount=32, blockLen=59*sizeof(T), srcBlkStride=0, srcRepStride=0, reserved=0
            // DataCopyPadExtParams参数：isPad=true, leftPadding=0, rightPadding=5
            // isPad=true时填充值为0，不使用SetPadValue
            AscendC::DataCopyExtParams copyParams{SRC_ROWS, SRC_COLS * sizeof(float), 0, 0, 0}; 
            AscendC::DataCopyPadExtParams<T> padParams;
            padParams.isPad = true;
            padParams.leftPadding = 0;
            padParams.rightPadding = DST_COLS - SRC_COLS;
            
            AscendC::DataCopyPad(srcLocal, srcGlobal, copyParams, padParams); 
        } else if constexpr (scenarioNum == 3) {
            // 场景3：使用Compact模式进行紧凑填充（仅支持 Ascend 950PR/Ascend 950DT）
            // DataCopyExtParams参数：blockCount=3, blockLen=24*sizeof(half), srcBlkStride=0, srcRepStride=0, reserved=0
            // DataCopyPadExtParams参数：isPad=true, leftPadding=0, rightPadding=56
            // PaddingMode::Compact：将多行数据紧凑排列到一行，填充区域紧凑放置在数据之后
            // 输入[3, 24]紧凑排列为[1, 80]，前72个元素为3行数据，后8个元素为填充区域
            AscendC::DataCopyExtParams copyParams{SRC_ROWS, SRC_COLS * sizeof(T), 0, 0, 0}; 
            AscendC::DataCopyPadExtParams<T> padParams;
            padParams.isPad = true;
            padParams.leftPadding = 0;
            padParams.rightPadding = DST_COLS - SRC_COLS;
            
            AscendC::DataCopyPad<T, AscendC::PaddingMode::Compact>(srcLocal, srcGlobal, copyParams, padParams); 
        }
        
        inQueueSrc.EnQue<T>(srcLocal);
    }
    __aicore__ inline void Compute()
    {
        AscendC::LocalTensor<T> srcLocal = inQueueSrc.DeQue<T>();
        AscendC::LocalTensor<T> dstLocal = outQueueDst.AllocTensor<T>();
        AscendC::Adds(dstLocal, srcLocal, scalar, DST_TOTAL_LENGTH);
        outQueueDst.EnQue(dstLocal);
        inQueueSrc.FreeTensor(srcLocal);
    }
    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> dstLocal = outQueueDst.DeQue<T>();
        AscendC::DataCopyExtParams copyParams{1, DST_TOTAL_LENGTH * sizeof(T), 0, 0, 0};
        AscendC::DataCopyPad(dstGlobal, dstLocal, copyParams); 
        outQueueDst.FreeTensor(dstLocal);
    }
private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueSrc;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueDst;
    AscendC::GlobalTensor<T> srcGlobal;
    AscendC::GlobalTensor<T> dstGlobal;
    AscendC::DataCopyPadExtParams<T> padParams;
    AscendC::DataCopyExtParams copyParams;
    T scalar = 0;
};

__global__ __vector__ void data_copy_pad_custom(GM_ADDR x, GM_ADDR z) 
{
    AscendC::TPipe pipe;
    if constexpr (scenarioNum == 2) {
        KernelDataCopyPad<float> op;
        op.Init(x, z, &pipe);
        op.Process();
    } else {
        KernelDataCopyPad<half> op;
        op.Init(x, z, &pipe);
        op.Process();
    }
}

int32_t main(int32_t argc, char* argv[]) 
{
    uint32_t numBlocks = 1;
    size_t elementSize = 0;

    if constexpr (scenarioNum == 2) {
        elementSize = sizeof(float);
    } else {
        elementSize = sizeof(half);
    }

    size_t inputByteSize = SRC_ROWS * SRC_COLS * elementSize;
    size_t outputByteSize = DST_TOTAL_LENGTH * elementSize;

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *zHost;
    uint8_t *xDevice, *zDevice;

    aclrtMallocHost((void **)(&xHost), inputByteSize);
    aclrtMallocHost((void **)(&zHost), outputByteSize);
    aclrtMalloc((void **)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void **)&zDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize,
                ACL_MEMCPY_HOST_TO_DEVICE);

    data_copy_pad_custom<<<numBlocks, nullptr, stream>>>(xDevice, zDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(zHost, outputByteSize, zDevice, outputByteSize,
                ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", zHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(zDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(zHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}