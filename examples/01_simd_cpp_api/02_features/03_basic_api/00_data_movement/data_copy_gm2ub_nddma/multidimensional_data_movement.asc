/* !
 * \file multidimensional_data_movement.asc
 * \brief 使用多维数据搬运接口（DataCopy）实现二维数据Padding/Transpose等功能，仅支持Ascend 950PR/Ascend 950DT
 */

#include "acl/acl.h"
#include "data_utils.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

#if defined(SCENARIO_NUM) && (SCENARIO_NUM == 1)
    constexpr uint32_t SRC_TOTAL_LENGTH = 16 * 32;
    constexpr uint32_t DST_TOTAL_LENGTH = 32 * 64;
#elif defined(SCENARIO_NUM) && (SCENARIO_NUM == 2)
    constexpr uint32_t SRC_TOTAL_LENGTH = 28 * 15;
    constexpr uint32_t DST_TOTAL_LENGTH = 32 * 32;
#elif defined(SCENARIO_NUM) && (SCENARIO_NUM == 3)
    constexpr uint32_t SRC_TOTAL_LENGTH = 16 * 64;
    constexpr uint32_t DST_TOTAL_LENGTH = 64 * 16;
#elif defined(SCENARIO_NUM) && (SCENARIO_NUM == 4)
    constexpr uint32_t SRC_TOTAL_LENGTH = 1 * 16;
    constexpr uint32_t DST_TOTAL_LENGTH = 3 * 16;
#elif defined(SCENARIO_NUM) && (SCENARIO_NUM == 5)
    constexpr uint32_t SRC_TOTAL_LENGTH = 32 * 64;
    constexpr uint32_t DST_TOTAL_LENGTH = 16 * 16;
#else
    constexpr uint32_t SRC_TOTAL_LENGTH = 16 * 32;
    constexpr uint32_t DST_TOTAL_LENGTH = 32 * 64;
#endif

template <typename T>
class KernelDataCopy {
public:
    __aicore__ inline KernelDataCopy() {}
    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y, uint32_t xCountIn, uint32_t yCountIn, AscendC::TPipe* pipeIn)
    {
        this->pipe = pipeIn;
        this->xCount = xCountIn;
        this->yCount = yCountIn;

        this->xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        this->yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y));
        this->pipe->InitBuffer(inQueueX, 1, xCount * sizeof(T));
        this->pipe->InitBuffer(outQueueY, 1, yCount * sizeof(T));
    }
    __aicore__ inline void Process()
    {
        CopyIn();
        CopyOut();
    }

private:
    __aicore__ inline void CopyIn()
    {
        AscendC::LocalTensor<T> xLocal = inQueueX.AllocTensor<T>();
        AscendC::Duplicate<T>(xLocal, 0, xCount);

        if constexpr (scenarioNum == 1) {
            // 场景1：2D Padding场景
            // xGmShape：[16, 32]，搬运8列2行数据，左Padding 15，上Padding 13，右Padding 17，下Padding 3，xLocalShape：[32, 64]
            AscendC::NdDmaLoopInfo<2> loopInfo{{1, 32}, {1, 64}, {32, 16}, {15, 13}, {17, 3}};
            AscendC::NdDmaParams<T, 2> params{loopInfo, 0};  // padding的值为0
            AscendC::NdDmaDci();  // 刷新cache
            static constexpr AscendC::NdDmaConfig dmaConfig;  // 使用默认参数，也可以不传
            AscendC::DataCopy<T, 2, dmaConfig>(xLocal, xGm, params);
        } else if constexpr (scenarioNum == 2) {
            // 场景2：2D Padding场景，使能最近值填充方式
            // xGmShape：[28, 15]，搬运3列4行数据，左Padding 11，上Padding 3，右Padding 6，下Padding 1，xLocalShape：[32, 32]
            AscendC::NdDmaLoopInfo<2> loopInfo{{1, 15}, {1, 32}, {15, 28}, {11, 3}, {6, 1}};
            AscendC::NdDmaParams<T, 2> params{loopInfo, 0}; 
            AscendC::NdDmaDci();  // 刷新cache
            // isNearestValueMode = true 左右Padding值会选取当前维度最左或最右的值进行填充
            static constexpr AscendC::NdDmaConfig dmaConfig = {true};
            AscendC::DataCopy<T, 2, dmaConfig>(xLocal, xGm, params);
        } else if constexpr (scenarioNum == 3) {
            // 场景3：2D Transpose场景
            // xGmShape：[16, 64]，搬运8列4行数据，xLocalShape：[64, 16]
            AscendC::NdDmaLoopInfo<2> loopInfo{{1, 64}, {16, 1}, {64, 16}, {0, 0}, {0, 0}};
            AscendC::NdDmaParams<T, 2> params{loopInfo, 0}; 
            AscendC::NdDmaDci();  // 刷新cache
            static constexpr AscendC::NdDmaConfig dmaConfig;  // 使用默认参数，也可以不传
            AscendC::DataCopy<T, 2, dmaConfig>(xLocal, xGm, params);
        } else if constexpr (scenarioNum == 4) {
            // 场景4：2D BroadCast场景
            // xGmShape：[1, 16]，搬运16列1行数据并进行广播，xLocalShape：[3, 16]
            AscendC::NdDmaLoopInfo<2> loopInfo{{1, 0}, {1, 16}, {16, 3}, {0, 0}, {0, 0}};
            AscendC::NdDmaParams<T, 2> params{loopInfo, 0}; 
            AscendC::NdDmaDci();  // 刷新cache
            static constexpr AscendC::NdDmaConfig dmaConfig;  // 使用默认参数，也可以不传
            AscendC::DataCopy<T, 2, dmaConfig>(xLocal, xGm, params);
        } else if constexpr (scenarioNum == 5) {
            // 场景5：2D Slice场景
            // xGmShape：[32, 64]，将16*10的矩阵截取为一个5*7的矩阵，xLocalShape：[16, 16]
            AscendC::NdDmaLoopInfo<2> loopInfo{{1, 64}, {1, 16}, {16, 16}, {0, 0}, {0, 0}};
            AscendC::NdDmaParams<T, 2> params{loopInfo, 0}; 
            AscendC::NdDmaDci();  // 刷新cache
            static constexpr AscendC::NdDmaConfig dmaConfig;  // 使用默认参数，也可以不传
            AscendC::DataCopy<T, 2, dmaConfig>(xLocal, xGm, params);
        } 
    
        inQueueX.EnQue(xLocal);
    }

    __aicore__ inline void CopyOut()
    {
        AscendC::LocalTensor<T> xLocal = inQueueX.DeQue<T>();
        AscendC::LocalTensor<T> yLocal = outQueueY.AllocTensor<T>();
        AscendC::DataCopy(yLocal, xLocal, yCount);
        outQueueY.EnQue<T>(yLocal);
        inQueueX.FreeTensor(xLocal);

        AscendC::LocalTensor<T> yOutLocal = outQueueY.DeQue<T>();
        AscendC::DataCopy(yGm, yOutLocal, yCount);
        outQueueY.FreeTensor(yOutLocal);
    }

private:
    AscendC::TPipe* pipe;
    AscendC::TQue<AscendC::TPosition::VECIN, 1> inQueueX;
    AscendC::TQue<AscendC::TPosition::VECOUT, 1> outQueueY;
    AscendC::GlobalTensor<T> xGm, yGm;
    uint32_t xCount, yCount;
};

__global__ __vector__ void datacopy_custom(GM_ADDR x, GM_ADDR y)
{
    AscendC::TPipe pipe;
    KernelDataCopy<float> op;
    op.Init(x, y, SRC_TOTAL_LENGTH, DST_TOTAL_LENGTH, &pipe);
    op.Process();
}

int32_t main(int32_t argc, char* argv[])
{
    uint32_t numBlocks = 1;
    size_t inputByteSize = SRC_TOTAL_LENGTH * sizeof(float);
    size_t outputByteSize = DST_TOTAL_LENGTH * sizeof(float);

    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);

    uint8_t *xHost, *yHost;
    uint8_t *xDevice, *yDevice;

    aclrtMallocHost((void**)(&xHost), inputByteSize);
    aclrtMallocHost((void**)(&yHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, inputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);

    ReadFile("./input/input_x.bin", inputByteSize, xHost, inputByteSize);

    aclrtMemcpy(xDevice, inputByteSize, xHost, inputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);

    datacopy_custom<<<numBlocks, nullptr, stream>>>(xDevice, yDevice);
    aclrtSynchronizeStream(stream);

    aclrtMemcpy(yHost, outputByteSize, yDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    WriteFile("./output/output.bin", yHost, outputByteSize);

    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFreeHost(xHost);
    aclrtFreeHost(yHost);

    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();

    return 0;
}
