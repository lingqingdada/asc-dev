#include <vector>
#include <iostream>
#include <iterator>
#include "acl/acl.h"
#include "kernel_operator.h"

#ifdef ASCENDC_CPU_DEBUG
#include "cpu_debug_launch.h"
#endif

constexpr uint32_t scenarioNum = SCENARIO_NUM;

template <typename T>
__simd_vf__ inline void CopySucceVF(__ubuf__ T* dstAddr, __ubuf__ T* srcAddr, uint16_t oneRepeatSize, uint32_t repeatTimes,
                               uint32_t count)
{
    AscendC::Reg::RegTensor<T> reg;
    AscendC::Reg::MaskReg mask;
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        // read from ub
        AscendC::Reg::LoadAlign(reg, srcAddr + i * oneRepeatSize);
        // write to ub
        AscendC::Reg::StoreAlign(dstAddr + i * oneRepeatSize, reg, mask);
    }
}

template <typename T>
__simd_vf__ inline void CopySucceWithPostModeVF(__ubuf__ T* dstAddr, __ubuf__ T* srcAddr, uint16_t oneRepeatSize,
                                           uint32_t repeatTimes, uint32_t count)
{
    AscendC::Reg::RegTensor<T> reg;
    AscendC::Reg::MaskReg mask;
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        // read from ub
        AscendC::Reg::LoadAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(reg, srcAddr, oneRepeatSize);
        // write to ub
        AscendC::Reg::StoreAlign<T, AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dstAddr, reg, oneRepeatSize,
                                                                                           mask);
    }
}

template <typename T>
__simd_vf__ inline void CopyUnSucceVF(__ubuf__ T* dstAddr, __ubuf__ T* srcAddr, uint16_t oneRepeatSize, uint32_t repeatTimes,
                               uint32_t count)
{
    AscendC::Reg::RegTensor<T> reg;
    AscendC::Reg::MaskReg mask;
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        // read from ub
        AscendC::Reg::LoadAlign<T, AscendC::Reg::DataCopyMode::DATA_BLOCK_COPY>(
            reg, srcAddr + i * oneRepeatSize, 1, mask);
        // write to ub
        AscendC::Reg::StoreAlign<T, AscendC::Reg::DataCopyMode::DATA_BLOCK_COPY>(dstAddr + i * oneRepeatSize,
                                                                                           reg, 1, mask);
    }
}

template <typename T>
__simd_vf__ inline void CopyUnSucceWithPostModeVF(__ubuf__ T* dstAddr, __ubuf__ T* srcAddr, uint16_t oneRepeatSize,
                                           uint32_t repeatTimes, uint32_t count)
{
    AscendC::Reg::RegTensor<T> reg;
    AscendC::Reg::MaskReg mask;
    // repeatStride单位为32B，oneRepeatSize个元素对应 oneRepeatSize*sizeof(T) 字节
    // 即 oneRepeatSize*sizeof(T)/32 个32B块
    uint32_t repeatStride = oneRepeatSize * sizeof(T) / 32;
    for (uint16_t i = 0; i < repeatTimes; ++i) {
        mask = AscendC::Reg::UpdateMask<T>(count);
        // read from ub
        AscendC::Reg::LoadAlign<T, AscendC::Reg::DataCopyMode::DATA_BLOCK_COPY,
                                     AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(reg, srcAddr, 1, repeatStride, mask);
        // write to ub
        AscendC::Reg::StoreAlign<T, AscendC::Reg::DataCopyMode::DATA_BLOCK_COPY,
                                      AscendC::Reg::PostLiteral::POST_MODE_UPDATE>(dstAddr, reg, 1, repeatStride, mask);
    }
}

template <typename T>
class Kernel {
public:
    __aicore__ inline void Init(GM_ADDR x, GM_ADDR y, uint32_t count)
    {
        this->count = count;
        this->xGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(x));
        this->yGm.SetGlobalBuffer(reinterpret_cast<__gm__ T*>(y));
    }

    __aicore__ inline void Process()
    {
        // 使用 LocalMemAllocator 分配 UB 内存
        AscendC::LocalMemAllocator<AscendC::Hardware::UB> ubAllocator;
        AscendC::LocalTensor<T> xLocal = ubAllocator.Alloc<T>(count);
        AscendC::LocalTensor<T> yLocal = ubAllocator.Alloc<T>(count);

        // CopyIn: GM -> UB
        AscendC::DataCopy(xLocal, xGm, count);

        // 同步：等待 MTE2 完成
        AscendC::SetFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::MTE2_V>(EVENT_ID0);

        // Compute: 使用 VF_CALL 进行数据搬移，通过编译期宏选择场景
        // 先将yLocal初始化为0，确保未被搬运覆盖的位置有确定值
        AscendC::Duplicate(yLocal, (T)0, count);
        __ubuf__ T* srcAddr = reinterpret_cast<__ubuf__ T*>(xLocal.GetPhyAddr());
        __ubuf__ T* dstAddr = reinterpret_cast<__ubuf__ T*>(yLocal.GetPhyAddr());
        constexpr uint32_t oneRepeatSize = AscendC::GetVecLen() / sizeof(T);
        uint16_t repeatTimes = AscendC::CeilDivision(count, oneRepeatSize);
        if constexpr (scenarioNum == 1) {
            // 场景1：连续搬运
            AscendC::VF_CALL<CopySucceVF<T>>(dstAddr, srcAddr, oneRepeatSize, repeatTimes, count);
        } else if constexpr (scenarioNum == 2) {
            // 场景2：连续搬运(postUpdate模式)
            AscendC::VF_CALL<CopySucceWithPostModeVF<T>>(dstAddr, srcAddr, oneRepeatSize, repeatTimes, count);
        } else if constexpr (scenarioNum == 3) {
            // 场景3：非连续搬运
            AscendC::VF_CALL<CopyUnSucceVF<T>>(dstAddr, srcAddr, oneRepeatSize, repeatTimes, count);
        } else if constexpr (scenarioNum == 4) {
            // 场景4：非连续搬运(postUpdate模式)
            AscendC::VF_CALL<CopyUnSucceWithPostModeVF<T>>(dstAddr, srcAddr, oneRepeatSize, repeatTimes, count);
        }

        // 同步：等待 V 完成
        AscendC::SetFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);
        AscendC::WaitFlag<AscendC::HardEvent::V_MTE3>(EVENT_ID0);

        // CopyOut: UB -> GM
        AscendC::DataCopy(yGm, yLocal, count);
    }

private:
    uint32_t count;
    AscendC::GlobalTensor<T> xGm;
    AscendC::GlobalTensor<T> yGm;
};

__global__ __vector__ void ld_st_reg_align_kernel(GM_ADDR x, GM_ADDR y)
{
    AscendC::InitSocState();
    Kernel<float> kernel;
    kernel.Init(x, y, 1024);
    kernel.Process();
    AscendC::PipeBarrier<PIPE_ALL>();
}

std::vector<float> ld_st_reg_align(std::vector<float>& input)
{
    uint32_t input_length = input.size();
    uint32_t numBlocks = 1;
    aclInit(nullptr);
    int32_t deviceId = 0;
    aclrtSetDevice(deviceId);
    aclrtStream stream = nullptr;
    aclrtCreateStream(&stream);
    size_t aInputByteSize = static_cast<size_t>(1) * input_length * sizeof(float);
    size_t outputByteSize = static_cast<size_t>(1) * input_length * sizeof(float);
    uint8_t *yHost;
    uint8_t *xDevice, *yDevice;
    aclrtMallocHost((void**)(&yHost), outputByteSize);
    aclrtMalloc((void**)&xDevice, aInputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMalloc((void**)&yDevice, outputByteSize, ACL_MEM_MALLOC_HUGE_FIRST);
    aclrtMemcpy(xDevice, aInputByteSize, input.data(), aInputByteSize, ACL_MEMCPY_HOST_TO_DEVICE);
    ld_st_reg_align_kernel<<<numBlocks, nullptr, stream>>>(xDevice, yDevice);
    aclrtSynchronizeStream(stream);
    aclrtMemcpy(yHost, outputByteSize, yDevice, outputByteSize, ACL_MEMCPY_DEVICE_TO_HOST);
    std::vector<float> output((float*)yHost, (float*)(yHost + outputByteSize));
    aclrtFree(xDevice);
    aclrtFree(yDevice);
    aclrtFreeHost(yHost);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return output;
}

uint32_t verify_result(std::vector<float>& output, std::vector<float>& golden)
{
    auto print_tensor = [](std::vector<float>& tensor, const char* name) {
        constexpr size_t max_print_size = 20;
        std::cout << name << ": ";
        std::copy(tensor.begin(), tensor.begin() + std::min(tensor.size(), max_print_size),
            std::ostream_iterator<float>(std::cout, " "));
        if (tensor.size() > max_print_size) {
            std::cout << "...";
        }
        std::cout << std::endl;
    };
    print_tensor(output, "Output");
    print_tensor(golden, "Golden");
    constexpr float EPS = 1e-5;
    bool pass = true;
    for (size_t i = 0; i < output.size(); i++) {
        if (std::abs(output[i] - golden[i]) > EPS) {
            pass = false;
            break;
        }
    }
    if (pass) {
        std::cout << "test pass!" << std::endl;
        return 0;
    } else {
        std::cout << "test fail!" << std::endl;
        return 1;
    }
}

int32_t main(int32_t argc, char* argv[])
{
    std::vector<float> input(1024);
    std::vector<float> golden(1024);
    for (uint32_t i = 0; i < 1024; i++){
        input[i] = i;
        golden[i] = i;
    }
    std::vector<float> output = ld_st_reg_align(input);
    return verify_result(output, golden);
}
